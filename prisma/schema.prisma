// ============================================
// AUTH MODELS (NextAuth)
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("CUSTOMER")
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// CATALOG MODELS
// ============================================

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Drop {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  startsAt    DateTime?
  endsAt      DateTime?
  published   Boolean   @default(false)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published])
}

model Product {
  id               String  @id @default(cuid())
  name             String
  slug             String  @unique
  sku              String  @unique
  shortDescription String
  description      String?
  price            Decimal
  categoryId       String?
  dropId           String?
  editionLimit     Int     @default(20)
  status           String  @default("DRAFT")
  featured         Boolean @default(false)

  category   Category?        @relation(fields: [categoryId], references: [id])
  drop       Drop?            @relation(fields: [dropId], references: [id])
  images     ProductImage[]
  variants   ProductVariant[]
  units      EditionUnit[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([dropId])
  @@index([status])
  @@index([featured])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariant {
  id        String @id @default(cuid())
  productId String
  size      String
  stock     Int    @default(0)

  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  units      EditionUnit[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, size])
  @@index([productId])
}

model EditionUnit {
  id            String    @id @default(cuid())
  productId     String
  variantId     String?
  serialNumber  Int
  status        String    @default("AVAILABLE")
  motifNote     String?
  reservedUntil DateTime?
  orderItemId   String?   @unique

  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  orderItem OrderItem?      @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, serialNumber])
  @@index([productId])
  @@index([variantId])
  @@index([status])
}

// ============================================
// ORDER MODELS
// ============================================

model Order {
  id             String @id @default(cuid())
  orderNumber    String @unique
  idempotencyKey String @unique

  customerName  String
  customerEmail String
  customerPhone String
  addressLine1  String
  city          String
  province      String
  postalCode    String?
  country       String  @default("Indonesia")
  notes         String?

  subtotal          Decimal
  shippingCost      Decimal @default(0)
  total             Decimal
  status            String  @default("AWAITING_PAYMENT")
  paymentStatus     String  @default("UNPAID")
  fulfillmentStatus String  @default("UNFULFILLED")
  internalNote      String?

  // Payment fields (PayPal)
  paymentMethod    String? // e.g. "PAYPAL"
  paypalOrderId    String?   @unique
  paypalCaptureId  String?
  paypalPayerId    String?
  paypalPayerEmail String?
  paidAt           DateTime?
  paymentResponse  String? // JSON snapshot of last webhook payload
  expiredAt        DateTime?

  // Refund fields (set when admin issues a PayPal refund)
  // The order can only be refunded after it has been PAID. refundId is the
  // PayPal refund transaction ID (for reconciliation with PayPal dashboard).
  // refundAmount is in the order's original currency (e.g. IDR), and is
  // converted to the capture currency at refund time (see lib/paypal.ts).
  // An order is considered "refunded" if refundedAt is non-null.
  refundedAt   DateTime?
  refundAmount Decimal?
  refundReason String?
  refundId     String?

  // Order view access (for the /checkout/success/[orderNumber] page)
  // Random 32-byte token, base64url encoded. Required to view the order's
  // customer PII. Sent in the success URL on the redirect.
  // SECURITY: Anyone with the token can view the order, so it must be
  // treated like a password — never log, never index, never commit.
  viewToken          String?   @unique
  viewTokenExpiresAt DateTime?

  // Customer tracking token (for the /track/[orderNumber] page).
  // Separate from viewToken because the tracking page is intended for
  // long-lived access (1 year) — it lets customers check shipment status
  // post-purchase without needing to log in or save the success URL.
  // Same HMAC + random-token pattern as viewToken (see lib/order-token.ts).
  trackingToken          String?   @unique
  trackingTokenExpiresAt DateTime?

  // Shipment tracking (set by admin when marking order as shipped)
  trackingNumber  String?
  trackingCarrier String? // e.g. "JNE", "SiCepat", "J&T"
  shippedAt       DateTime?
  deliveredAt     DateTime?

  // Discount / promo code (one code per order; see DiscountCode model)
  discountCode   String?
  discountType   String? // "PERCENTAGE" | "FIXED" (matches DiscountCode.type at time of use)
  discountValue  Decimal? // original value (e.g. 20 for 20%, or 50000 for fixed)
  discountAmount Decimal  @default(0) // actual discount applied (in order currency)

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([paymentStatus])
  @@index([customerEmail])
  @@index([createdAt])
  @@index([paypalOrderId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  variantId String?
  name      String
  size      String
  price     Decimal
  quantity  Int

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  unit    EditionUnit?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

// ============================================
// DISCOUNT / PROMO CODES
// ============================================
// One code per order (no stacking). Codes can be:
//   - PERCENTAGE: e.g. 20 = 20% off subtotal (capped at maxDiscount if set)
//   - FIXED: e.g. 50000 = Rp 50.000 off subtotal (capped at subtotal)
//
// Usage tracking:
//   - usageLimit: total redemptions allowed (null = unlimited)
//   - perCustomerLimit: redemptions per customer email (null = unlimited)
//   - usageCount: incremented atomically when a code is applied to an order
//
// DiscountUsage records each redemption for audit + per-customer limit checks.

model DiscountCode {
  id               String    @id @default(cuid())
  code             String    @unique // e.g. "LAUNCH20", uppercase
  type             String // "PERCENTAGE" | "FIXED"
  value            Decimal // 20 (% = 0..100) or fixed amount (e.g. 50000)
  minPurchase      Decimal? // minimum order subtotal to apply (null = no min)
  maxDiscount      Decimal? // PERCENTAGE only: cap on discount amount
  expiresAt        DateTime? // null = no expiry
  usageLimit       Int? // total uses allowed (null = unlimited)
  usageCount       Int       @default(0)
  perCustomerLimit Int? // uses per customer email (null = unlimited)
  active           Boolean   @default(true)
  description      String? // internal admin note

  usages DiscountUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([active])
  @@index([expiresAt])
}

model DiscountUsage {
  id            String  @id @default(cuid())
  discountId    String
  orderId       String  @unique // one code per order (no stacking)
  customerEmail String
  amount        Decimal // actual discount applied at time of use

  discount DiscountCode @relation(fields: [discountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([discountId, customerEmail])
  @@index([customerEmail])
}

// ============================================
// LEAD & MARKETING MODELS
// ============================================

model ContactSubmission {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
}

model WaitlistEntry {
  id           String   @id @default(cuid())
  productId    String?
  dropId       String?
  fullName     String
  email        String
  phone        String?
  sizeInterest String?
  status       String   @default("NEW")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productId])
  @@index([dropId])
  @@index([email])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// CMS MODELS
// ============================================

model Page {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  content        String
  seoTitle       String?
  seoDescription String?
  published      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// ARTICLE / BLOG MODELS
// ============================================

model Article {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  excerpt        String?
  content        String
  coverImage     String?
  authorName     String?
  published      Boolean   @default(false)
  featured       Boolean   @default(false)
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([slug])
  @@index([published])
  @@index([featured])
  @@index([publishedAt])
}

// ============================================
// AUDIT LOG (security trail for admin actions)
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  action    String // e.g. "product.create", "order.update_status", "settings.update"
  resource  String? // e.g. "Product:cmxxx", "Order:cmyyy"
  details   String? // JSON snapshot of changes
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resource])
}

// ============================================
// WEBHOOK EVENT DEDUPLICATION
// ============================================
// Prevents double-processing of retried webhooks
// (e.g. PayPal retries if our response is slow).
// `id` is the provider's unique event id.

model WebhookEvent {
  id          String   @id // Provider event id (e.g. PayPal event.id)
  provider    String // "paypal", "stripe", etc. (future-proof)
  type        String // Event type for observability
  resourceId  String? // Optional reference to resource (e.g. order id)
  processedAt DateTime @default(now())

  @@index([provider])
  @@index([processedAt])
}
