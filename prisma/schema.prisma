// ============================================
// HEUSE - Prisma Schema
// Database: PostgreSQL (Railway / Supabase)
// ============================================
//
// PROVIDER: postgresql (production-ready)
// URL: Set via DATABASE_URL in prisma.config.ts (Prisma 7 adapter pattern)
//
// Local Development (PostgreSQL via Docker):
//   DATABASE_URL="postgresql://postgres:***@localhost:5432/heuse_dev"
//
// Production (Railway Postgres):
//   DATABASE_URL="postgresql://postgres:***@<host>.railway.app:5432/railway"
//
// Production (Supabase alternative):
//   DATABASE_URL="postgresql://postgres:***@db.<ref>.supabase.co:5432/postgres"
//
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

