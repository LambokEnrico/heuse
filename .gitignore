# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files - NEVER commit real values
.env
.env.local
.env.*.local
.env.production
.env.production.local
.env.development
# ✅ DO commit placeholder template:
!.env.example

# vercel (legacy)
/.vercel

# Railway
/.railway

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma auto-generated
/app/generated/prisma

# Local SQLite (for dev-only testing)
/dev.db
/dev.db-journal

# Build artifacts
/.next
/build


# Generic logs
*.log
